num1 = 12
num2 = 18
gcd = 1 # We start with 1, because 1 divides everything!

# Step 1: Find the smaller number
if num1 < num2:
    smaller_number = num1
else:
    smaller_number = num2

# Step 2: Count from 1 up to the smaller_number
# 'range(1, smaller_number + 1)' generates numbers like 1, 2, 3... up to smaller_number
for i in range(1, smaller_number + 1):
    
    # Check if 'i' divides BOTH numbers perfectly
    if (num1 % i == 0) and (num2 % i == 0):
        gcd = i # If it does, we save it! It will overwrite smaller matches.

print("The GCD is:", gcd)
